      },
      "query": "\n\nselect\n  post_id,\n  created_at,\n  type,\n  title,\n  body,\n  owner_user_id,\n  parent_id\nfrom\n  `dataform-open-source.staging.stg_posts_answers`\n\nunion all\n\nselect\n  post_id,\n  created_at,\n  type,\n  title,\n  body,\n  owner_user_id,\n  parent_id\nfrom\n  `dataform-open-source.staging.stg_posts_questions`",
